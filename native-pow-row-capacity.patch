diff --git a/services/miner-api/vllm-v010/vllm/v1/sample/ops/topk_topp_sampler.py b/services/miner-api/vllm-v010/vllm/v1/sample/ops/topk_topp_sampler.py
--- a/services/miner-api/vllm-v010/vllm/v1/sample/ops/topk_topp_sampler.py
+++ b/services/miner-api/vllm-v010/vllm/v1/sample/ops/topk_topp_sampler.py
@@ -506,8 +506,29 @@ class PowTopKTopPSampler(TopKTopPSampler):
     # ---------- initialisation ----------------------------------------- #
     def __init__(self,
-                 max_concurrency: int = 1024,
+                 max_concurrency: int | None = None,
                  eos_token_id: int = 2,
                  window_size: int = POW_WINDOW_SIZE,
                  device: torch.device | None = None):
+        # vLLM can temporarily hand the sampler both running rows and its
+        # bounded waiting reserve. The historical fixed 1024-row pool then
+        # evicted rows from the same batch at a 1024+ request profile. That
+        # made get_row() return None later in this forward pass and crashed
+        # EngineCore at torch.as_tensor(rows). Size this proof-only row pool
+        # from the launcher-provided vLLM ceiling plus reserve instead.
+        #
+        # TensorCash row pool must cover every possible vLLM sample row. This
+        # changes only local bookkeeping capacity; it never changes logits,
+        # sampling, proof bytes, or consensus validation.
+        if max_concurrency is None:
+            raw_capacity = os.getenv("POW_MAX_CONCURRENCY", "1024").strip()
+            try:
+                max_concurrency = int(raw_capacity)
+            except ValueError as exc:
+                raise RuntimeError(
+                    "POW_MAX_CONCURRENCY must be a positive integer") from exc
+        if not 1 <= max_concurrency <= 4096:
+            raise RuntimeError(
+                "POW_MAX_CONCURRENCY must be between 1 and 4096")
+
         super().__init__()                               # keep FlashInfer hook
         self._common = CommonSamplerHelper(self)
