         self._total_completion_tokens = 0
         self._total_completions = 0
 
+    def set_nomp_model_config(self, *, name: str, commit: str, model_hash: str, difficulty: int) -> None:
+        """Install the NOMP job's chain-authoritative model parameters.
+
+        The local sidecar is intentionally unable to discover a model from a
+        remote registry.  It only accepts parameters embedded in an already
+        authenticated NOMP work unit, then uses those values for the exact
+        target adjustment passed to the proof-producing inference request.
+        """
+        if not constants.NOMP_SIDECAR_ENABLED:
+            raise RuntimeError("NOMP model configuration is disabled")
+        if not name or not commit or difficulty < 1:
+            raise ValueError("NOMP model name, commit, and positive difficulty are required")
+        self._nomp_model_config = constants.ModelConfig(
+            model_hash=model_hash,
+            model_name=name,
+            model_commit=commit,
+            difficulty=difficulty,
+        )
+
+    async def generate_nomp_dummy(self, model_name: str) -> None:
+        """Run one local-sidecar mining request without registry auto-selection."""
+        if not constants.NOMP_SIDECAR_ENABLED:
+            raise RuntimeError("NOMP dummy generation is disabled")
+        if not self.session or self.session.closed:
+            raise RuntimeError("request manager HTTP session is not ready")
+        config = self._nomp_model_config
+        if not config or config.model_name != model_name:
+            raise RuntimeError("NOMP work unit has no active matching model configuration")
+        dummy_id = f"nomp-{self.context.read().request_id}-{uuid.uuid4().hex[:12]}"
+        self.active_requests[dummy_id] = time.time()
+        self._register_dummy_task(dummy_id)
+        try:
+            prompt = self.prompt_generator.generate_prompt()
+            if constants.MINING_DISABLE_THINKING:
+                prompt = f"{prompt} {constants.MINING_NO_THINK_DIRECTIVE}"
+            data = self._inject_pow_data({
+                "model": model_name,
+                "prompt": prompt,
+                "max_tokens": 256,
+                "temperature": 1.0,
+                "top_k": 50,
+                "top_p": 1.0,
+                "request_id": dummy_id,
+                "ignore_eos": True,
+            })
+            async with self.session.post(
+                f"{self._backend_base_url(model_name)}/v1/completions",
+                json=data,
+                headers=self.auth_headers,
+                timeout=aiohttp.ClientTimeout(total=constants.DUMMY_REQUEST_TIMEOUT),
+            ) as response:
+                body = await response.read()
+                if response.status >= 400:
+                    raise RuntimeError(f"vLLM rejected NOMP dummy: HTTP {response.status}: {body[:200]!r}")
+                self._record_token_usage(body)
+        finally:
+            self._unregister_dummy_task(dummy_id)
+            self.active_requests.pop(dummy_id, None)
+
     def _load_runtime_model_state(self) -> None:
         """Restore runtime model selection from disk if a state file exists."""
         path = self._runtime_model_state_path
