# `start.sh` creates miner.env securely on first launch. Do not publish it.
# The image is a public binary artifact produced from a private build pipeline;
# it contains no Rust source checkout and does not contain model weights.
# After its published Blackwell image is available, `start.sh` selects it on
# compute capability 12.x GPUs. Until then it fails clearly and directs the
# user to native-vast.sh; it never persists a manifest-unknown image tag.
MINER_IMAGE=ghcr.io/avalonbtc/tensorcash-miner:mainnet-0.1.0
# Blackwell override, only after that tag has been published:
# MINER_IMAGE=ghcr.io/avalonbtc/tensorcash-miner:mainnet-0.1.1-blackwell
POOL_HOST=pool.example.org
POOL_PORT=3336
PAYOUT_ACCOUNT=replace-with-your-payout-address
WORKER=rig-01
NOMP_SIDECAR_TOKEN=replace-with-a-local-random-token

# Chain-pinned mainnet model. Change these only as a complete profile update
# published by the pool operator.
MODEL_NAME=Qwen/Qwen3-8B
MODEL_COMMIT=9c925d64d72725edaf899c6cb9c377fd0709d9c5
MODEL_DIFFICULTY_NORMALIZER=1000000
MAX_MODEL_LEN=2048
# At every mining start the launcher repairs missing Git metadata when needed,
# force-syncs to origin/main, and re-execs the updated script. Disable only
# for a deliberate offline recovery.
TENSORCASH_AUTO_UPDATE=true
# Automatic precision policy: 6/8 GiB pairs use FP8 TP=2; 12--21.9 GiB TP=1
# cards use the verified serialized FP8 artifact; >=22 GiB TP=1 cards use
# BF16. This avoids the online BF16-to-FP8 conversion peak that can also OOM a
# 16 GiB card. Set fp8 or bf16 only to force a deliberate profile.
TENSORCASH_MODEL_PRECISION=auto
# The serialized FP8 artifact is hard-pinned to
# Qwen/Qwen3-8B-FP8@220b46e3b2180893580a4454f21f22d3ebb187d3. An existing
# verified copy below MODELS_DATA can be selected with:
# TENSORCASH_STATIC_FP8_SNAPSHOT=/absolute/path/below/MODELS_DATA
# Shared high-utilization default. If a particular host cannot complete the
# capacity probe, lower this only for that host and rerun start.sh.
GPU_MEM_UTIL=0.89
# On a failed vLLM bootstrap, wait for all TP workers to exit and for the
# selected GPUs to be effectively idle before retrying. These defaults avoid
# overlapping retries that falsely report insufficient VRAM on 2x12 GB rigs.
TENSORCASH_VLLM_CLEANUP_TIMEOUT_SECONDS=120
TENSORCASH_VLLM_CLEANUP_MAX_USED_MIB=512

# Default: resolve a safe vLLM cap from the actual TP/VRAM group, start at 32,
# and retain higher levels only when rolling generation throughput improves.
# Set TENSORCASH_CONCURRENCY_MODE=manual only for a deliberate fixed benchmark.
TENSORCASH_CONCURRENCY_MODE=auto
TENSORCASH_AUTO_CONCURRENCY_START=32
TENSORCASH_AUTO_CONCURRENCY_STEP=32
# No VRAM-tier concurrency ceiling: vLLM admission and measured generation
# decide where auto mode stops. 1024 only bounds accidental coroutine storms.
TENSORCASH_AUTO_CONCURRENCY_CEILING=1024
# A new concurrency level needs two complete rate windows before it is kept or
# rolled back. This prevents one block/VDF transition from making an identical
# GPU appear permanently slower than its peers.
NOMP_SIDECAR_ADAPTIVE_CONFIRM_WINDOWS=2
# Maximum claimed proofs waiting for terminal pool responses. Keep it at or
# below NOMP_SIDECAR_CONCURRENCY; the default is deliberately conservative.
TENSORCASH_SUBMIT_WINDOW=16

# `auto` plans one independent serialized-FP8 group for each 12--21.9 GiB card, one FP8
# TP=2 group for every pair of 6/8 GiB cards, and one independent BF16 group
# for each >=22 GiB card.
# Legacy BF16 TP groups remain available when forced.
# You can override it explicitly, for example 0,1,2,3 or 0,1;2,3.
GPU_GROUPS=auto

# A single host-local model cache is shared by every group. Runtime data is
# automatically separated per group by start.sh.
MODELS_DATA=/opt/tensorcash-miner/models
RUNTIME_DATA=/opt/tensorcash-miner/data
TENSORCASH_POLL_MS=200
TENSORCASH_STATS_INTERVAL=30
TENSORCASH_SIDECAR_WAIT_SECONDS=1200
