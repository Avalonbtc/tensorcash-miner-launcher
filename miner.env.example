# `start.sh` creates miner.env securely on first launch. Do not publish it.
# The image is a public binary artifact produced from a private build pipeline;
# it contains no Rust source checkout and does not contain model weights.
MINER_IMAGE=ghcr.io/avalonbtc/tensorcash-miner:mainnet-0.1.0
POOL_HOST=pool.example.org
POOL_PORT=3336
PAYOUT_ACCOUNT=replace-with-your-payout-address
WORKER=rig-01
NOMP_SIDECAR_TOKEN=replace-with-a-local-random-token

# Chain-pinned mainnet model. Change these only as a complete profile update
# published by the pool operator.
MODEL_NAME=Qwen/Qwen3-8B
MODEL_COMMIT=9c925d64d72725edaf899c6cb9c377fd0709d9c5
MODEL_DIFFICULTY_NORMALIZER=1000000
MAX_MODEL_LEN=2048
VLLM_MAX_NUM_SEQS=1
GPU_MEM_UTIL=0.78

# Keep this equal to or below VLLM_MAX_NUM_SEQS.  Start at 1; the validated
# 4090 profile will use 4 with a bounded local proof queue.
NOMP_SIDECAR_CONCURRENCY=1
NOMP_SIDECAR_MIN_BUFFERED_PROOFS=2
NOMP_SIDECAR_MAX_BUFFERED_PROOFS=8

# `auto` plans valid TP groups from the detected VRAM: one >=22 GiB GPU,
# pairs of >=11 GiB GPUs, or groups of four >=7.5 GiB GPUs. You can override
# it explicitly, for example 0,1,2,3 or 0,1;2,3.
GPU_GROUPS=auto

# A single host-local model cache is shared by every group. Runtime data is
# automatically separated per group by start.sh.
MODELS_DATA=/opt/tensorcash-miner/models
RUNTIME_DATA=/opt/tensorcash-miner/data
TENSORCASH_POLL_MS=200
TENSORCASH_STATS_INTERVAL=30
TENSORCASH_SIDECAR_WAIT_SECONDS=1200
