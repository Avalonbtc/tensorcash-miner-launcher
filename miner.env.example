# Copying is handled by start.sh on the first invocation. Do not publish the
# generated miner.env: it contains a payout ID.
MINER_IMAGE=ghcr.io/avalonbtc/tensortest-miner:0.1.0
POOL_HOST=119.91.239.215
POOL_PORT=3336
PAYOUT_ACCOUNT=replace-with-your-payout-address
WORKER=vast-4070s-01

# Current public test-pool profile. Do not edit model pin independently.
MODEL_NAME=Qwen/Qwen3-0.6B
MODEL_COMMIT=c1899de289a04d12100db370d81485cdf75e47ca
MODEL_DIFFICULTY_NORMALIZER=1000000
MAX_MODEL_LEN=2048
VLLM_MAX_NUM_SEQS=1
GPU_MEM_UTIL=0.78
NVIDIA_VISIBLE_DEVICES=0,1,2,3
VLLM_TENSOR_PARALLEL_SIZE=4

# Host-local persistent cache.
MODELS_DATA=./runtime/models
RUNTIME_DATA=./runtime/data
